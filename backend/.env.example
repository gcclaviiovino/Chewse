APP_NAME=Social Food AI Pipeline
APP_ENV=development
LOG_LEVEL=INFO

DEFAULT_LOCALE=it-IT
MAX_REQUEST_BYTES=1048576
ALLOWED_IMAGE_ROOTS=./tests
ENABLE_PIPELINE_DEBUG_LAST=false

LLM_BASE_URL=https://api.regolo.ai
LLM_MODEL=qwen3-vl-32b
LLM_TIMEOUT_SECONDS=60
LLM_RETRY_COUNT=2

EMBEDDING_BASE_URL=https://api.regolo.ai
EMBEDDING_MODEL=Qwen3-Embedding-8B
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_RETRY_COUNT=2

REGOLO_API_KEY=
REGOLO_API_HEADER=Authorization
REGOLO_API_PREFIX=Bearer

OFF_BASE_URL=https://world.openfoodfacts.org/api/v2
OFF_USER_AGENT=SocialFoodBackend/1.0 (support@example.com)
OFF_TIMEOUT_CONNECT_SECONDS=5
OFF_TIMEOUT_READ_SECONDS=15
OFF_MAX_RETRIES=2
OFF_BACKOFF_BASE_MS=250
OFF_RESPECT_RETRY_AFTER=true
OFF_CACHE_ENABLED=true
OFF_CACHE_TTL_SECONDS=3600
OFF_CACHE_NOT_FOUND_TTL_SECONDS=300

REQUEST_TIMEOUT_SECONDS=60
RETRY_BACKOFF_BASE_SECONDS=0.25
RETRY_JITTER_SECONDS=0.1

CHROMA_PATH=./chroma
OFF_DATA_DIR=./data/off_subset
RAG_TOP_K=3
RAG_SCORE_THRESHOLD=0.35
RAG_METADATA_FILTERS=
SIMILAR_PRODUCTS_CANDIDATE_LIMIT=20
SIMILAR_PRODUCTS_SHORTLIST_SIZE=5
SIMILAR_PRODUCTS_SIMILARITY_THRESHOLD=0.35

LLM_INPUT_MAX_CHARS=4000
LLM_OUTPUT_MAX_CHARS=12000
EXPLANATION_SHORT_MAX_CHARS=320
EXPLANATION_BULLET_MAX_CHARS=220
